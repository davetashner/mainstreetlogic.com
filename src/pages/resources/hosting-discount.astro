---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageDescription =
  'Get 50% off your first year of website hosting with Main Street Logic. Enter your email to claim your exclusive discount code.';

const benefits = [
  {
    icon: '🚀',
    title: 'Lightning Fast',
    description: 'Sites load in under 2 seconds with global CDN',
  },
  {
    icon: '🔒',
    title: 'Secure & Reliable',
    description: 'Free SSL, daily backups, 99.9% uptime',
  },
  {
    icon: '🛠️',
    title: 'Fully Managed',
    description: 'Updates, security patches, and monitoring included',
  },
  {
    icon: '📞',
    title: 'Direct Support',
    description: 'Talk to a developer, not a ticket queue',
  },
];
---

<BaseLayout
  title="50% Off Hosting - Limited Offer"
  description={pageDescription}
>
  <!-- Hero Section -->
  <section class="bg-navy py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span
        class="inline-block bg-steel-blue/30 text-steel-blue text-sm font-medium px-4 py-1.5 rounded-full mb-6"
      >
        Limited Time Offer
      </span>
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-6">
        Get <span class="text-steel-blue">50% Off</span> Your First Year of Hosting
      </h1>
      <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">
        Professional website hosting without the headaches. No hidden fees, no
        long-term contracts, no surprises.
      </p>

      <!-- Pricing Preview -->
      <div
        class="inline-flex items-center gap-4 bg-white/10 rounded-lg px-6 py-4"
      >
        <div class="text-left">
          <span class="text-white/60 text-sm block">Regular price</span>
          <span class="text-white/60 text-xl line-through">$15/month</span>
        </div>
        <div class="text-left border-l border-white/20 pl-4">
          <span class="text-steel-blue text-sm block">With discount</span>
          <span class="text-white text-2xl font-bold">$7.50/month</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Email Form Section -->
  <section class="py-12 md:py-16 bg-light-bg dark:bg-dark-bg">
    <div class="max-w-xl mx-auto px-4">
      <div
        class="bg-white dark:bg-navy rounded-xl p-8 shadow-lg border border-soft-gray/30 dark:border-soft-gray/20"
      >
        <!-- Form State: Initial -->
        <div id="form-container">
          <h2
            class="text-2xl font-bold text-navy dark:text-white text-center mb-2"
          >
            Claim Your Discount Code
          </h2>
          <p class="text-navy/70 dark:text-soft-gray/70 text-center mb-6">
            Enter your email and we'll send you the exclusive discount code.
          </p>

          <form id="discount-form" class="space-y-4">
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-navy dark:text-soft-gray mb-2"
              >
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-soft-gray dark:border-soft-gray/30 rounded-md bg-white dark:bg-navy text-navy dark:text-soft-gray focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="you@example.com"
              />
            </div>

            <!-- Honeypot field -->
            <div class="hidden" aria-hidden="true">
              <label for="website">Website</label>
              <input
                type="text"
                id="website"
                name="website"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <!-- Error message -->
            <div
              id="form-error"
              class="hidden text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-md p-3 text-sm"
            >
              <span id="error-message"
                >Something went wrong. Please try again.</span
              >
            </div>

            <button
              type="submit"
              id="submit-button"
              class="w-full bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-dark-steel transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
            >
              <span id="button-text">Get My Discount Code</span>
              <svg
                id="button-spinner"
                class="hidden animate-spin h-5 w-5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"
                  fill="none"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
              </svg>
            </button>
          </form>

          <p
            class="text-xs text-navy/50 dark:text-soft-gray/50 text-center mt-4"
          >
            No spam. We'll only contact you about your hosting discount.
          </p>
        </div>

        <!-- Success State -->
        <div id="success-container" class="hidden text-center">
          <div
            class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600 dark:text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-navy dark:text-white mb-2">
            Here's Your Discount Code!
          </h2>
          <p class="text-navy/70 dark:text-soft-gray/70 mb-6">
            Use this code when signing up for hosting:
          </p>

          <!-- Coupon Code Display -->
          <div
            class="bg-steel-blue/10 dark:bg-steel-blue/20 border-2 border-dashed border-steel-blue rounded-lg p-6 mb-6"
          >
            <span
              id="coupon-code"
              class="text-3xl font-mono font-bold text-navy dark:text-white tracking-wider"
            >
              HALFOFF2024
            </span>
          </div>

          <p class="text-sm text-navy/60 dark:text-soft-gray/60 mb-6">
            This code gives you <strong>50% off your first year</strong> of hosting.
            Valid for new clients only.
          </p>

          <a
            href="/contact"
            class="inline-block bg-steel-blue text-white font-medium rounded-md px-8 py-3 hover:bg-dark-steel transition-colors no-underline"
          >
            Get Started with Hosting
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2
        class="text-2xl md:text-3xl font-bold text-navy dark:text-white text-center mb-12"
      >
        What's Included in Your Hosting
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        {
          benefits.map((benefit) => (
            <div class="flex gap-4 p-6 bg-white dark:bg-navy rounded-lg shadow-sm border border-soft-gray/30 dark:border-soft-gray/20">
              <span class="text-3xl flex-shrink-0">{benefit.icon}</span>
              <div>
                <h3 class="font-semibold text-navy dark:text-white mb-1">
                  {benefit.title}
                </h3>
                <p class="text-navy/70 dark:text-soft-gray/70 text-sm">
                  {benefit.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 md:py-16 bg-soft-gray/30 dark:bg-navy/50">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-navy dark:text-white text-center mb-8">
        Common Questions
      </h2>

      <div class="space-y-4">
        <details
          class="bg-white dark:bg-navy rounded-lg p-6 border border-soft-gray/30 dark:border-soft-gray/20"
        >
          <summary class="font-medium text-navy dark:text-white cursor-pointer">
            How long is the discount valid?
          </summary>
          <p class="mt-3 text-navy/70 dark:text-soft-gray/70">
            The 50% discount applies to your first 12 months of hosting. After
            that, you'll pay the regular rate of $15/month.
          </p>
        </details>

        <details
          class="bg-white dark:bg-navy rounded-lg p-6 border border-soft-gray/30 dark:border-soft-gray/20"
        >
          <summary class="font-medium text-navy dark:text-white cursor-pointer">
            Is there a long-term contract?
          </summary>
          <p class="mt-3 text-navy/70 dark:text-soft-gray/70">
            No contracts. You can cancel anytime with 30 days notice. We believe
            you should stay because you want to, not because you're locked in.
          </p>
        </details>

        <details
          class="bg-white dark:bg-navy rounded-lg p-6 border border-soft-gray/30 dark:border-soft-gray/20"
        >
          <summary class="font-medium text-navy dark:text-white cursor-pointer">
            Can I use this with an existing website?
          </summary>
          <p class="mt-3 text-navy/70 dark:text-soft-gray/70">
            This discount is for new hosting clients. If you have an existing
            site elsewhere, we can help migrate it at no extra charge.
          </p>
        </details>

        <details
          class="bg-white dark:bg-navy rounded-lg p-6 border border-soft-gray/30 dark:border-soft-gray/20"
        >
          <summary class="font-medium text-navy dark:text-white cursor-pointer">
            What if I need a new website too?
          </summary>
          <p class="mt-3 text-navy/70 dark:text-soft-gray/70">
            We build custom websites for small businesses. This hosting discount
            can be combined with our website development services.
            <a href="/services" class="text-steel-blue hover:underline"
              >See our services</a
            >.
          </p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CONTACT_API_URL = import.meta.env.PUBLIC_CONTACT_API_URL || '';

  const form = document.getElementById('discount-form') as HTMLFormElement;
  const formContainer = document.getElementById(
    'form-container'
  ) as HTMLDivElement;
  const successContainer = document.getElementById(
    'success-container'
  ) as HTMLDivElement;
  const submitButton = document.getElementById(
    'submit-button'
  ) as HTMLButtonElement;
  const buttonText = document.getElementById('button-text') as HTMLSpanElement;
  const buttonSpinner = document.getElementById('button-spinner') as SVGElement;
  const errorEl = document.getElementById('form-error') as HTMLDivElement;
  const errorMessage = document.getElementById(
    'error-message'
  ) as HTMLSpanElement;

  function showError(message: string): void {
    errorEl.classList.remove('hidden');
    errorMessage.textContent = message;
  }

  function hideError(): void {
    errorEl.classList.add('hidden');
  }

  function setLoading(loading: boolean): void {
    submitButton.disabled = loading;
    if (loading) {
      buttonText.textContent = 'Sending...';
      buttonSpinner.classList.remove('hidden');
    } else {
      buttonText.textContent = 'Get My Discount Code';
      buttonSpinner.classList.add('hidden');
    }
  }

  function showSuccess(): void {
    formContainer.classList.add('hidden');
    successContainer.classList.remove('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const website = formData.get('website') as string; // honeypot

    // Basic email validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      showError('Please enter a valid email address.');
      return;
    }

    if (!CONTACT_API_URL) {
      // Fallback: Show success anyway if API not configured (for testing)
      showSuccess();
      return;
    }

    setLoading(true);

    try {
      const response = await fetch(CONTACT_API_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name: 'Hosting Discount Request',
          email: email,
          message:
            'Requested 50% hosting discount code via /resources/hosting-discount page.',
          website: website, // honeypot
        }),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        showSuccess();
      } else {
        showError(result.error || 'Failed to submit. Please try again.');
      }
    } catch (err) {
      console.error('Discount form error:', err);
      showError('Network error. Please check your connection and try again.');
    } finally {
      setLoading(false);
    }
  });
</script>
