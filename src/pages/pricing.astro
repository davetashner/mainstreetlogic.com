---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';

const hostingPlans = [
  {
    title: 'Basic Hosting',
    price: '$12',
    description: 'Perfect for simple business websites',
    features: [
      'Static website hosting',
      'SSL certificate included',
      'CDN for fast loading',
      'Basic analytics',
      'Email support',
    ],
  },
  {
    title: 'Pro Hosting',
    price: '$15',
    description: 'For sites that need more',
    features: [
      'Everything in Basic',
      'Contact form handling',
      'Monthly backups',
      'Priority support',
      'Uptime monitoring',
    ],
    highlighted: true,
  },
];

const faqs = [
  {
    question: 'How does project pricing work?',
    answer:
      "We provide fixed-price quotes for defined projects, or we can work on an hourly basis. After an initial consultation, we'll provide a clear estimate so there are no surprises.",
  },
  {
    question: 'What is The Backlog Model?',
    answer:
      'For ongoing clients, we maintain a prioritized list of improvements and features for your systems. You control the priorities, and we work through items as your budget allows. This gives you predictable costs while ensuring continuous improvement.',
  },
  {
    question: 'Do you offer monthly retainers?',
    answer:
      'Yes. For clients who need ongoing support, we offer monthly retainer arrangements that guarantee availability and often come with discounted hourly rates.',
  },
  {
    question: "What's included in a free consultation?",
    answer:
      "A 30-minute call where we learn about your business, understand your challenges, and discuss whether we're a good fit to help. No pressure, no obligation.",
  },
];
---

<BaseLayout
  title="Pricing"
  description="Transparent pricing for small business technology consulting. Monthly hosting plans, project work, and flexible engagement models."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-light-bg to-soft-gray dark:from-dark-bg dark:to-navy py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-navy dark:text-soft-gray mb-6">
        Simple, Transparent Pricing
      </h1>
      <p class="text-xl text-navy/70 dark:text-soft-gray/70">
        No hidden fees. No surprises. Just honest pricing for quality work.
      </p>
    </div>
  </section>

  <!-- Hosting Plans -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-navy dark:text-soft-gray mb-4 text-center">
        Monthly Hosting Plans
      </h2>
      <p class="text-center text-navy/70 dark:text-soft-gray/70 mb-12 max-w-2xl mx-auto">
        Keep your website running smoothly with our managed hosting. Everything
        you need, nothing you don't.
      </p>

      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        {
          hostingPlans.map((plan) => (
            <PricingCard
              title={plan.title}
              price={plan.price}
              description={plan.description}
              features={plan.features}
              highlighted={plan.highlighted}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Project Work -->
  <section class="bg-white dark:bg-navy py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-navy dark:text-soft-gray mb-4 text-center">
        Project Work
      </h2>
      <p class="text-center text-navy/70 dark:text-soft-gray/70 mb-12 max-w-2xl mx-auto">
        For larger initiatives, we provide custom quotes based on your specific
        needs.
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-light-bg dark:bg-dark-bg rounded-lg p-6 text-center">
          <h3 class="font-semibold text-navy dark:text-soft-gray mb-2">Small Projects</h3>
          <p class="text-2xl font-bold text-steel-blue mb-2">$500 - $2,000</p>
          <p class="text-sm text-navy/60 dark:text-soft-gray/60">
            Simple websites, basic automation, quick integrations
          </p>
        </div>
        <div class="bg-light-bg dark:bg-dark-bg rounded-lg p-6 text-center">
          <h3 class="font-semibold text-navy dark:text-soft-gray mb-2">Medium Projects</h3>
          <p class="text-2xl font-bold text-steel-blue mb-2">
            $2,000 - $10,000
          </p>
          <p class="text-sm text-navy/60 dark:text-soft-gray/60">
            Custom applications, complex integrations, full site redesigns
          </p>
        </div>
        <div class="bg-light-bg dark:bg-dark-bg rounded-lg p-6 text-center">
          <h3 class="font-semibold text-navy dark:text-soft-gray mb-2">Large Projects</h3>
          <p class="text-2xl font-bold text-steel-blue mb-2">Let's Chat</p>
          <p class="text-sm text-navy/60 dark:text-soft-gray/60">
            Multi-system overhauls, complex requirements
          </p>
        </div>
      </div>

      <p class="text-center text-navy/60 dark:text-soft-gray/60 mt-8 text-sm">
        These are general ranges. Every project is quoted individually based on
        your specific requirements.
      </p>
    </div>
  </section>

  <!-- The Backlog Model -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-navy rounded-lg p-8 md:p-12">
        <h2 class="text-3xl font-bold text-white mb-4">The Backlog Model</h2>
        <p class="text-white/80 mb-6">
          Technology needs don't stop after the initial build. The Backlog Model
          is our approach to ongoing improvement:
        </p>
        <ul class="space-y-4 text-white/80">
          <li class="flex items-start gap-3">
            <span class="text-steel-blue font-bold">1.</span>
            <span
              >We maintain a prioritized list of improvements, features, and
              fixes for your systems.</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-steel-blue font-bold">2.</span>
            <span
              >You control the priorities based on what matters most to your
              business.</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-steel-blue font-bold">3.</span>
            <span>We work through items at a pace that fits your budget.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-steel-blue font-bold">4.</span>
            <span
              >Your systems get better continuously, without big up-front
              investments.</span
            >
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white dark:bg-navy py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-navy dark:text-soft-gray mb-12 text-center">
        Frequently Asked Questions
      </h2>

      <div class="space-y-6">
        {
          faqs.map((faq) => (
            <div class="border-b border-soft-gray dark:border-soft-gray/20 pb-6">
              <h3 class="text-xl font-semibold text-navy dark:text-soft-gray mb-2">
                {faq.question}
              </h3>
              <p class="text-navy/70 dark:text-soft-gray/70">{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-navy py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to get started?</h2>
      <p class="text-xl text-white/70 mb-8">
        Schedule a free consultation to discuss your project and get a custom
        quote.
      </p>
      <a
        href="/contact"
        class="inline-block bg-steel-blue text-white font-medium rounded-md px-8 py-4 hover:bg-medium-steel transition-colors no-underline"
      >
        Schedule Free Consultation
      </a>
    </div>
  </section>
</BaseLayout>
