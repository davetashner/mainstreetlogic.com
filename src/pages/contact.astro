---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Main Street Logic. Schedule a consultation or send us a message."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-light-bg to-soft-gray py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-6">
        Let's Talk
      </h1>
      <p class="text-xl text-navy/70">
        Ready to simplify your technology? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Send a Message</h2>
          <form class="space-y-6" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-navy mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-navy mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label for="business" class="block text-sm font-medium text-navy mb-2">
                Business Name (optional)
              </label>
              <input
                type="text"
                id="business"
                name="business"
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="Your business"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent resize-none"
                placeholder="Tell us about your project or question..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-dark-steel transition-colors"
            >
              Send Message
            </button>
          </form>
          <p class="text-sm text-navy/60 mt-4">
            We typically respond within 1 business day.
          </p>
        </div>

        <!-- Contact Info & Booking -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Other Ways to Reach Us</h2>

          <!-- Direct Contact -->
          <div class="bg-white rounded-lg p-6 shadow-sm border border-soft-gray/50 mb-6">
            <h3 class="font-semibold text-navy mb-4">Direct Contact</h3>
            <ul class="space-y-3 text-navy/70">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:hello@mainstreetlogic.com" class="hover:text-steel-blue">
                  hello@mainstreetlogic.com
                </a>
              </li>
            </ul>
          </div>

          <!-- Book a Call -->
          <div class="bg-navy rounded-lg p-6">
            <h3 class="font-semibold text-white mb-4">Schedule a Free Consultation</h3>
            <p class="text-white/70 mb-4">
              Book a 30-minute call to discuss your business needs. No pressure, no obligation.
            </p>
            <!-- Calendly placeholder - replace with actual embed or link -->
            <div class="bg-white/10 rounded-lg p-8 text-center">
              <p class="text-white/60 text-sm mb-4">Calendly booking widget coming soon</p>
              <a
                href="mailto:hello@mainstreetlogic.com?subject=Consultation%20Request"
                class="inline-block bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-medium-steel transition-colors no-underline"
              >
                Request a Call
              </a>
            </div>
          </div>

          <!-- Response Time -->
          <div class="mt-6 p-4 bg-soft-gray/30 rounded-lg">
            <p class="text-sm text-navy/70">
              <strong class="text-navy">Quick Response:</strong> We respond to all inquiries
              within 1 business day. For urgent matters, please mention it in your message.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
