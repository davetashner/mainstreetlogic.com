---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Main Street Logic. Schedule a consultation or send us a message."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-light-bg to-soft-gray py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-6">Let's Talk</h1>
      <p class="text-xl text-navy/70">
        Ready to simplify your technology? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Send a Message</h2>
          <form id="contact-form" class="space-y-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-navy mb-2"
              >
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="Your name"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-navy mb-2"
              >
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label
                for="business"
                class="block text-sm font-medium text-navy mb-2"
              >
                Business Name (optional)
              </label>
              <input
                type="text"
                id="business"
                name="business"
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent"
                placeholder="Your business"
              />
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-navy mb-2"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-soft-gray rounded-md focus:outline-none focus:ring-2 focus:ring-steel-blue focus:border-transparent resize-none"
                placeholder="Tell us about your project or question..."
              ></textarea>
            </div>

            <!-- Honeypot field - hidden from users, bots will fill it -->
            <div class="hidden" aria-hidden="true">
              <label for="website">Website</label>
              <input
                type="text"
                id="website"
                name="website"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <!-- Status message -->
            <div id="form-status" class="hidden">
              <div
                id="form-loading"
                class="hidden text-navy/70 flex items-center gap-2"
              >
                <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24">
                  <circle
                    class="opacity-25"
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="currentColor"
                    stroke-width="4"
                    fill="none"></circle>
                  <path
                    class="opacity-75"
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                  ></path>
                </svg>
                Sending...
              </div>
              <div
                id="form-success"
                class="hidden text-green-700 bg-green-50 border border-green-200 rounded-md p-4"
              >
                Thank you for your message! We'll get back to you within 1
                business day.
              </div>
              <div
                id="form-error"
                class="hidden text-red-700 bg-red-50 border border-red-200 rounded-md p-4"
              >
                <span id="error-message"
                  >Something went wrong. Please try again.</span
                >
              </div>
            </div>

            <button
              type="submit"
              id="submit-button"
              class="w-full bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-dark-steel transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Send Message
            </button>
          </form>
          <p class="text-sm text-navy/60 mt-4">
            We typically respond within 1 business day.
          </p>
        </div>

        <!-- Contact Info & Booking -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">
            Other Ways to Reach Us
          </h2>

          <!-- Direct Contact -->
          <div
            class="bg-white rounded-lg p-6 shadow-sm border border-soft-gray/50 mb-6"
          >
            <h3 class="font-semibold text-navy mb-4">Direct Contact</h3>
            <ul class="space-y-3 text-navy/70">
              <li class="flex items-center gap-3">
                <svg
                  class="w-5 h-5 text-steel-blue"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <a
                  href="mailto:hello@mainstreetlogic.com"
                  class="hover:text-steel-blue"
                >
                  hello@mainstreetlogic.com
                </a>
              </li>
            </ul>
          </div>

          <!-- Book a Call -->
          <div class="bg-navy rounded-lg p-6">
            <h3 class="font-semibold text-white mb-4">
              Schedule a Free Consultation
            </h3>
            <p class="text-white/70 mb-4">
              Book a 30-minute call to discuss your business needs. No pressure,
              no obligation.
            </p>
            <!-- Calendly placeholder - replace with actual embed or link -->
            <div class="bg-white/10 rounded-lg p-8 text-center">
              <p class="text-white/60 text-sm mb-4">
                Calendly booking widget coming soon
              </p>
              <a
                href="mailto:hello@mainstreetlogic.com?subject=Consultation%20Request"
                class="inline-block bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-medium-steel transition-colors no-underline"
              >
                Request a Call
              </a>
            </div>
          </div>

          <!-- Response Time -->
          <div class="mt-6 p-4 bg-soft-gray/30 rounded-lg">
            <p class="text-sm text-navy/70">
              <strong class="text-navy">Quick Response:</strong> We respond to all
              inquiries within 1 business day. For urgent matters, please mention
              it in your message.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const CONTACT_API_URL = import.meta.env.PUBLIC_CONTACT_API_URL || '';

    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitButton = document.getElementById(
      'submit-button'
    ) as HTMLButtonElement;
    const statusContainer = document.getElementById(
      'form-status'
    ) as HTMLDivElement;
    const loadingEl = document.getElementById('form-loading') as HTMLDivElement;
    const successEl = document.getElementById('form-success') as HTMLDivElement;
    const errorEl = document.getElementById('form-error') as HTMLDivElement;
    const errorMessage = document.getElementById(
      'error-message'
    ) as HTMLSpanElement;

    function showStatus(
      type: 'loading' | 'success' | 'error',
      message?: string
    ) {
      statusContainer.classList.remove('hidden');
      loadingEl.classList.add('hidden');
      successEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      if (type === 'loading') {
        loadingEl.classList.remove('hidden');
      } else if (type === 'success') {
        successEl.classList.remove('hidden');
      } else if (type === 'error') {
        errorEl.classList.remove('hidden');
        if (message) {
          errorMessage.textContent = message;
        }
      }
    }

    function hideStatus() {
      statusContainer.classList.add('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!CONTACT_API_URL) {
        showStatus(
          'error',
          'Contact form is not configured. Please email us directly.'
        );
        return;
      }

      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        business: formData.get('business'),
        message: formData.get('message'),
        website: formData.get('website'), // honeypot
      };

      submitButton.disabled = true;
      showStatus('loading');

      try {
        const response = await fetch(CONTACT_API_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          showStatus('success');
          form.reset();
        } else {
          showStatus(
            'error',
            result.error || 'Failed to send message. Please try again.'
          );
        }
      } catch (err) {
        console.error('Contact form error:', err);
        showStatus(
          'error',
          'Network error. Please check your connection and try again.'
        );
      } finally {
        submitButton.disabled = false;
      }
    });
  </script>
</BaseLayout>
