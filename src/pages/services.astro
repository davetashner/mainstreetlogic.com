---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Custom Software & Automation',
    description:
      'Stop doing repetitive tasks manually. We build custom tools and automated workflows that save you hours every week.',
    details: [
      'Custom internal tools and dashboards',
      'Workflow automation (Zapier, Make, custom scripts)',
      'Data processing and reporting automation',
      'Email and notification systems',
    ],
  },
  {
    title: 'Website Development',
    description:
      'Your website is often the first impression customers have of your business. We build fast, modern sites that work.',
    details: [
      'Business websites and landing pages',
      'E-commerce and online stores',
      'Website redesigns and updates',
      'Ongoing maintenance and hosting',
    ],
  },
  {
    title: 'System Integration',
    description:
      'Your tools should talk to each other. We connect your software so data flows automatically where it needs to go.',
    details: [
      'CRM and email marketing integration',
      'Payment and accounting sync',
      'Inventory management connections',
      'Custom API development',
    ],
  },
  {
    title: 'SaaS Audit & Optimization',
    description:
      "Most businesses are paying for software they don't fully use - or don't need at all. We help you find savings.",
    details: [
      'Software subscription review',
      'Duplicate tool elimination',
      'Better alternatives recommendations',
      'Cost-benefit analysis',
    ],
  },
  {
    title: 'Hourly Tech Consulting',
    description:
      'Sometimes you just need expert advice. Book time with us to discuss any technology question or challenge.',
    details: [
      'Technology strategy sessions',
      'Software selection guidance',
      'Vendor evaluation',
      'Technical problem-solving',
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Our technology consulting services for small businesses: custom software, website development, system integration, SaaS optimization, and more."
>
  <!-- Hero Section -->
  <section
    class="bg-gradient-to-br from-light-bg to-soft-gray dark:from-dark-bg dark:to-navy py-16 md:py-24"
  >
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1
        class="text-4xl md:text-5xl font-bold text-navy dark:text-soft-gray mb-6"
      >
        Services
      </h1>
      <p class="text-xl text-navy/70 dark:text-soft-gray/70">
        Technology solutions designed for the unique needs of small businesses.
      </p>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <div class="space-y-12">
        {
          services.map((service, index) => (
            <div class="bg-white dark:bg-navy rounded-lg p-8 shadow-sm border border-soft-gray/50 dark:border-soft-gray/20">
              <div class="md:flex md:items-start md:gap-8">
                <div class="flex-shrink-0 w-12 h-12 bg-steel-blue/10 rounded-lg flex items-center justify-center mb-4 md:mb-0">
                  <span class="text-steel-blue font-bold text-lg">
                    {index + 1}
                  </span>
                </div>
                <div class="flex-grow">
                  <h2 class="text-2xl font-semibold text-navy dark:text-soft-gray mb-3">
                    {service.title}
                  </h2>
                  <p class="text-navy/70 dark:text-soft-gray/70 mb-4">
                    {service.description}
                  </p>
                  <ul class="grid md:grid-cols-2 gap-2">
                    {service.details.map((detail) => (
                      <li class="flex items-start gap-2 text-navy/60 dark:text-soft-gray/60">
                        <svg
                          class="w-5 h-5 text-steel-blue mt-0.5 flex-shrink-0"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                        {detail}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-navy py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        Not sure what you need?
      </h2>
      <p class="text-xl text-white/70 mb-6">
        Let's talk. We'll help you figure out the best approach for your
        business.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 mb-8 text-white/80 text-sm">
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-steel-blue"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            />
          </svg>
          <span>Free 30-minute consultation</span>
        </div>
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-steel-blue"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            />
          </svg>
          <span>Satisfaction guaranteed</span>
        </div>
      </div>
      <a
        href="/contact"
        class="inline-block bg-steel-blue text-white font-medium rounded-md px-8 py-4 hover:bg-medium-steel transition-colors no-underline"
      >
        Schedule a Free Consultation
      </a>
    </div>
  </section>
</BaseLayout>
