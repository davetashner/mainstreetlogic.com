---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    title: 'Custom Software & Automation',
    description: 'Streamline your operations with custom tools and automated workflows tailored to your business.',
    icon: '⚙️'
  },
  {
    title: 'Website Development',
    description: 'Modern, fast websites that represent your business professionally and convert visitors to customers.',
    icon: '🌐'
  },
  {
    title: 'System Integration',
    description: 'Connect your tools and platforms so they work together seamlessly.',
    icon: '🔗'
  },
  {
    title: 'SaaS Audit & Optimization',
    description: 'Review your software subscriptions and find ways to reduce costs while improving efficiency.',
    icon: '📊'
  },
  {
    title: 'Hourly Tech Consulting',
    description: 'Get expert advice on any technology question, from choosing software to planning your tech strategy.',
    icon: '💡'
  },
];
---

<BaseLayout title="Home">
  <Hero
    title="Practical technology consulting for small business"
    subtitle="Helping Main Street businesses make smart decisions in a digital world."
    ctaText="Get Started"
    ctaHref="/contact"
  />

  <!-- Services Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">How We Help</h2>
        <p class="text-xl text-navy/70 max-w-2xl mx-auto">
          We provide technology solutions designed for the unique needs of small businesses.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
          />
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/services"
          class="inline-block border border-steel-blue text-steel-blue font-medium rounded-md px-6 py-3 hover:bg-steel-blue hover:text-white transition-colors no-underline"
        >
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-navy py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to simplify your technology?
      </h2>
      <p class="text-xl text-white/70 mb-8">
        Let's talk about how we can help your business run more efficiently.
      </p>
      <a
        href="/contact"
        class="inline-block bg-steel-blue text-white font-medium rounded-md px-8 py-4 hover:bg-medium-steel transition-colors no-underline"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
