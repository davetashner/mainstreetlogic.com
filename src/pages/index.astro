---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import GuaranteeBadge from '../components/GuaranteeBadge.astro';
import FAQ from '../components/FAQ.astro';
import Testimonials from '../components/Testimonials.astro';
import AvailabilityBadge from '../components/AvailabilityBadge.astro';

const siteUrl = 'https://mainstreetlogic.com';
const pageDescription =
  'Work directly with a developer, not an agency. Custom software, automation, and website development for small businesses. Save 10+ hours per week with solutions tailored to your workflow.';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Main Street Logic',
  description:
    'Technology consulting for small businesses. Custom software, automation, website development, and system integration.',
  url: siteUrl,
  logo: `${siteUrl}/images/logo.png`,
  sameAs: [],
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  priceRange: '$$',
  serviceType: [
    'Custom Software Development',
    'Business Automation',
    'Website Development',
    'System Integration',
    'SaaS Consulting',
    'Technology Consulting',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Technology Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Custom Software & Automation',
          description:
            'Streamline your operations with custom tools and automated workflows tailored to your business.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Development',
          description:
            'Modern, fast websites that represent your business professionally and convert visitors to customers.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'System Integration',
          description:
            'Connect your tools and platforms so they work together seamlessly.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'SaaS Audit & Optimization',
          description:
            'Review your software subscriptions and find ways to reduce costs while improving efficiency.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Hourly Tech Consulting',
          description:
            'Get expert advice on any technology question, from choosing software to planning your tech strategy.',
        },
      },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Main Street Logic',
  url: siteUrl,
};

const services = [
  {
    title: 'Custom Software & Automation',
    description:
      'Streamline your operations with custom tools and automated workflows tailored to your business.',
  },
  {
    title: 'Website Development',
    description:
      'Modern, fast websites that represent your business professionally and convert visitors to customers.',
  },
  {
    title: 'System Integration',
    description:
      'Connect your tools and platforms so they work together seamlessly.',
  },
  {
    title: 'SaaS Audit & Optimization',
    description:
      'Review your software subscriptions and find ways to reduce costs while improving efficiency.',
  },
  {
    title: 'Hourly Tech Consulting',
    description:
      'Get expert advice on any technology question, from choosing software to planning your tech strategy.',
  },
];
---

<BaseLayout title="Home" description={pageDescription}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  </Fragment>
  <Hero
    title="Tired of paying for software that doesn't work together?"
    subtitle="Work directly with a developer, not a revolving door of agency staff. Get real solutions from someone who understands both code and business."
    outcome="Save 10+ hours per week with custom automation tailored to your workflow."
    ctaText="Get Started"
    ctaHref="/contact"
    showAvailability={true}
    spotsAvailable={3}
    availabilityPeriod="this month"
  />

  <!-- Services Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12 animate-on-scroll">
        <h2
          class="text-3xl md:text-4xl font-bold text-navy dark:text-soft-gray mb-4"
        >
          How We Help
        </h2>
        <p
          class="text-xl text-navy/70 dark:text-soft-gray/70 max-w-2xl mx-auto"
        >
          We provide technology solutions designed for the unique needs of small
          businesses.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        <ServiceCard
          title={services[0].title}
          description={services[0].description}
        >
          <svg
            slot="icon"
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
          </svg>
        </ServiceCard>
        <ServiceCard
          title={services[1].title}
          description={services[1].description}
        >
          <svg
            slot="icon"
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.97.633-3.794 1.708-5.278"
            ></path>
          </svg>
        </ServiceCard>
        <ServiceCard
          title={services[2].title}
          description={services[2].description}
        >
          <svg
            slot="icon"
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
            ></path>
          </svg>
        </ServiceCard>
        <ServiceCard
          title={services[3].title}
          description={services[3].description}
        >
          <svg
            slot="icon"
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"
            ></path>
          </svg>
        </ServiceCard>
        <ServiceCard
          title={services[4].title}
          description={services[4].description}
        >
          <svg
            slot="icon"
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"
            ></path>
          </svg>
        </ServiceCard>
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="btn-secondary"> View All Services </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <Testimonials />

  <!-- How It Works Section -->
  <ProcessSteps />
  <!-- Guarantee Section -->
  <section class="py-16 md:py-20 bg-white dark:bg-navy">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8 animate-on-scroll">
        <h2
          class="text-3xl md:text-4xl font-bold text-navy dark:text-soft-gray mb-4"
        >
          Risk-Free to Get Started
        </h2>
        <p
          class="text-xl text-navy/70 dark:text-soft-gray/70 max-w-2xl mx-auto"
        >
          We understand small business owners are careful with every decision.
          That's why we make it easy to work with us.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto stagger-children">
        <GuaranteeBadge
          title="Satisfaction Guaranteed"
          description="Not happy with our first project? We'll make it right—no questions asked."
        />
        <GuaranteeBadge
          title="Free Consultation"
          description="30-minute consultation to discuss your needs. No pressure, no obligation."
        />
      </div>
    </div>
  </section>

  <!-- Free Resource Section -->
  <section class="py-12 md:py-16 bg-steel-blue/10 dark:bg-steel-blue/5">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2
        class="text-2xl md:text-3xl font-bold text-navy dark:text-soft-gray mb-3"
      >
        Free Resource
      </h2>
      <p
        class="text-lg text-navy/70 dark:text-soft-gray/70 mb-6 max-w-2xl mx-auto"
      >
        Not sure where to start? Download our Tech Friction Checklist to
        identify what's slowing your business down.
      </p>
      <a
        href="/resources/tech-friction-checklist"
        class="inline-flex items-center gap-2 bg-navy dark:bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-navy/90 dark:hover:bg-medium-steel transition-colors no-underline"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
          ></path>
        </svg>
        Get the Free Checklist
      </a>
      <p class="text-sm text-navy/60 dark:text-soft-gray/60 mt-3">
        No email required
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <FAQ />

  <!-- CTA Section -->
  <section class="bg-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to simplify your technology?
      </h2>
      <p class="text-xl text-white/70 mb-6">
        Let's talk about how we can help your business run more efficiently.
      </p>
      <div class="flex flex-col items-center gap-4">
        <a href="/contact" class="btn-primary px-8 py-4 text-lg">
          Schedule a Consultation
        </a>
        <AvailabilityBadge
          spotsAvailable={3}
          period="this month"
          variant="subtle"
          customMessage="Currently accepting 3 new clients per month"
        />
      </div>
    </div>
  </section>
</BaseLayout>
