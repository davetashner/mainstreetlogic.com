---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadCapture from '../components/LeadCapture.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const siteUrl = 'https://mainstreetlogic.com';

const {
  title,
  description = 'Practical technology consulting for small business. Helping Main Street businesses make smart decisions in a digital world.',
  ogImage = '/images/hero/hero-light.png',
  canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      href="/favicon.png"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      href="/favicon-dark.png"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload hero images for LCP optimization (theme-aware) -->
    <link
      rel="preload"
      href="/images/hero/hero-light.webp"
      as="image"
      type="image/webp"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="preload"
      href="/images/hero/hero-dark.webp"
      as="image"
      type="image/webp"
      media="(prefers-color-scheme: dark)"
    />

    <!-- Theme initialization (prevents FOUC) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia(
          '(prefers-color-scheme: dark)'
        ).matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>

    <!-- Primary Meta Tags -->
    <title>{title} | Main Street Logic</title>
    <meta name="title" content={`${title} | Main Street Logic`} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={`${title} | Main Street Logic`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:site_name" content="Main Street Logic" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={`${title} | Main Street Logic`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={absoluteOgImage} />

    <!-- Additional head content (structured data, etc.) -->
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-grow">
      <slot />
    </main>
    <Footer />
    <LeadCapture triggerPercent={50} dismissHours={24} />
  </body>
</html>
