---
import AvailabilityBadge from './AvailabilityBadge.astro';

interface Props {
  title: string;
  subtitle?: string;
  outcome?: string;
  ctaText?: string;
  ctaHref?: string;
  showImage?: boolean;
  /** Show availability badge below CTA for urgency */
  showAvailability?: boolean;
  /** Number of consultation spots available */
  spotsAvailable?: number;
  /** Time period for availability */
  availabilityPeriod?: string;
}

const {
  title,
  subtitle,
  outcome,
  ctaText,
  ctaHref,
  showImage = true,
  showAvailability = false,
  spotsAvailable = 3,
  availabilityPeriod = 'this month',
} = Astro.props;
---

<section
  class="relative bg-gradient-to-br from-light-bg to-soft-gray dark:from-dark-bg dark:to-navy py-16 md:py-24 overflow-hidden"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-15 dark:opacity-10" aria-hidden="true">
    {/* Light mode background pattern */}
    <img
      src="/images/bg_geometric_light.webp"
      alt=""
      class="w-full h-full object-cover dark:hidden"
    />
    {/* Dark mode background pattern */}
    <img
      src="/images/bg_geometric_dark.webp"
      alt=""
      class="w-full h-full object-cover hidden dark:block"
    />
  </div>

  <div class="max-w-6xl mx-auto px-4 relative">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1
          class="text-4xl md:text-5xl font-bold text-navy dark:text-soft-gray mb-6 leading-tight"
        >
          {title}
        </h1>
        {
          subtitle && (
            <p class="text-xl text-navy/70 dark:text-soft-gray/70 mb-4">
              {subtitle}
            </p>
          )
        }
        {
          outcome && (
            <p class="text-lg font-medium text-steel-blue dark:text-medium-steel mb-8">
              {outcome}
            </p>
          )
        }
        {
          ctaText && ctaHref && (
            <div class="space-y-3">
              <a
                href={ctaHref}
                class="inline-block bg-steel-blue text-white font-medium rounded-md px-6 py-3 hover:bg-dark-steel transition-colors no-underline"
              >
                {ctaText}
              </a>
              {showAvailability && (
                <div>
                  <AvailabilityBadge
                    spotsAvailable={spotsAvailable}
                    period={availabilityPeriod}
                    variant="subtle"
                  />
                </div>
              )}
            </div>
          )
        }
      </div>
      {
        showImage && (
          <div class="hidden md:block">
            {/* Light mode hero image */}
            <img
              src="/images/hero/hero-light.webp"
              alt="Main Street Logic"
              width="1536"
              height="1024"
              fetchpriority="high"
              class="w-full h-auto rounded-lg shadow-lg dark:hidden"
            />
            {/* Dark mode hero image */}
            <img
              src="/images/hero/hero-dark.webp"
              alt="Main Street Logic"
              width="1536"
              height="1024"
              fetchpriority="high"
              class="w-full h-auto rounded-lg shadow-lg hidden dark:block"
            />
          </div>
        )
      }
    </div>
  </div>
</section>
