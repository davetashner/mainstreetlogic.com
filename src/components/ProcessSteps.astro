---
const steps = [
  {
    number: 1,
    title: 'Free Consultation',
    description:
      'We start with a conversation to understand your business, challenges, and goals.',
  },
  {
    number: 2,
    title: 'Custom Proposal',
    description:
      'You receive a clear proposal with scope, timeline, and pricing tailored to your needs.',
  },
  {
    number: 3,
    title: 'Build & Iterate',
    description:
      'We develop your solution with regular check-ins to ensure it meets your expectations.',
  },
  {
    number: 4,
    title: 'Ongoing Support',
    description:
      'After launch, we provide training and support to keep everything running smoothly.',
  },
];
---

<section class="bg-soft-gray/30 dark:bg-navy/50 py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2
        class="text-3xl md:text-4xl font-bold text-navy dark:text-soft-gray mb-4"
      >
        How It Works
      </h2>
      <p class="text-xl text-navy/70 dark:text-soft-gray/70 max-w-2xl mx-auto">
        A simple, straightforward process to get your technology working for
        you.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        steps.map((step, index) => (
          <div class="relative text-center">
            {/* Connector line (hidden on mobile, shown between items on desktop) */}
            {index < steps.length - 1 && (
              <div class="hidden lg:block absolute top-8 left-1/2 w-full h-0.5 bg-steel-blue/20" />
            )}

            {/* Step number circle */}
            <div class="relative z-10 w-16 h-16 mx-auto mb-4 bg-steel-blue rounded-full flex items-center justify-center">
              <span class="text-2xl font-bold text-white">{step.number}</span>
            </div>

            {/* Content */}
            <h3 class="text-lg font-semibold text-navy dark:text-soft-gray mb-2">
              {step.title}
            </h3>
            <p class="text-navy/70 dark:text-soft-gray/70 text-sm">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
